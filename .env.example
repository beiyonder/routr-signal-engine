# Copy to .env for local development. Never commit .env.
# In GitHub Actions, set each as a repository secret (LLM_PROVIDER + LLM_MODEL
# may also live as repo Variables instead of Secrets).

# -----------------------------------------------------------------------------
# LLM provider split — classifier (cheap, high volume) vs drafter (flagship)
# -----------------------------------------------------------------------------
# Classifier: scores every fetched item that survives the cosine prefilter.
ROUTR_SIGNAL_LLM_PROVIDER=anthropic            # anthropic | gemini | openai
ROUTR_SIGNAL_LLM_MODEL=claude-haiku-4-5        # leave blank to use provider default

# Drafter: writes 5 post hooks per day. Worth spending more here.
ROUTR_SIGNAL_DRAFTER_PROVIDER=gemini           # leave blank to inherit classifier's
ROUTR_SIGNAL_DRAFTER_MODEL=gemini-3.1-pro-preview

# Per-provider classifier defaults if ROUTR_SIGNAL_LLM_MODEL is blank:
#   anthropic -> claude-haiku-4-5
#   gemini    -> gemini-3-flash-preview
#   openai    -> gpt-5-mini
# Per-provider drafter defaults:
#   anthropic -> claude-opus-4-7
#   gemini    -> gemini-3.1-pro-preview
#   openai    -> gpt-5

# -----------------------------------------------------------------------------
# API keys — only the selected provider's key is actually used,
# but you can stash all three so you can switch fast.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxx
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-proj-xxx

# -----------------------------------------------------------------------------
# Outputs — Discord is primary. Others are optional; leave blank to skip.
# -----------------------------------------------------------------------------

# Discord webhook. Use the NATIVE Discord webhook URL (no /slack suffix).
# Our output module emits Discord-native rich embeds, not Slack-compat blocks.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../

# Optional — Slack
SLACK_WEBHOOK_URL=

# Optional — Email (SMTP)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# -----------------------------------------------------------------------------
# Phase 6 — Firecrawl (weekly TokScale + OpenRouter scrapes)
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=fc-xxx

# -----------------------------------------------------------------------------
# X / Twitter source (twikit primary, Playwright + cookies fallback)
# -----------------------------------------------------------------------------
# Burner account credentials. NEVER use a personal account.
# Run `python tools/twitter_login.py` once on a dev machine to populate
# data/cache/twitter-cookies.json from a real browser session.
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
TWITTER_TOTP_SECRET=            # optional, if 2FA is enabled on the burner

# Base64 of data/cache/twitter-cookies.json, set as GitHub Actions secret
# so the headless Playwright fallback can authenticate on CI runners.
TWITTER_COOKIES_B64=

# Throttle for X reads (low and slow keeps the burner alive). Default 30s.
ROUTR_SIGNAL_TWITTER_DELAY_S=30

# -----------------------------------------------------------------------------
# Discord bot — used by tasks/dispatch_approved.py for reaction polling.
# Bot must be invited to the same server as DISCORD_WEBHOOK_URL above,
# with permissions=68672 (View Channel, Send Messages, Read Message History,
# Add Reactions). REST polling only; no gateway connection.
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=                   # used for signature verification if we add buttons later
DISCORD_CHANNEL_ID=                   # the channel id where the digest is posted

# -----------------------------------------------------------------------------
# Buffer — GraphQL bearer for posting to X (the only auto-wired channel).
# LinkedIn is intentionally posted manually from the digest text.
# -----------------------------------------------------------------------------
BUFFER_ACCESS_TOKEN=
BUFFER_ORG_ID=
BUFFER_X_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Beehiiv — newsletter publish (drafts only; user clicks Send in the UI).
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=               # `pub_<uuid>` format (v2 API)

# -----------------------------------------------------------------------------
# X dev account — currently unused. X moved to pay-per-use in Feb 2026 and
# the free tier returns 402 on most read endpoints, so the feedback loop is
# deferred. Kept here for optionality if we later post directly.
# -----------------------------------------------------------------------------
X_API_BEARER_TOKEN=
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=

# -----------------------------------------------------------------------------
# Behavior flags
# -----------------------------------------------------------------------------
ROUTR_SIGNAL_SOURCES=hn,reddit,github_issues,twitter,discord_paste,hf_papers,newsletters
ROUTR_SIGNAL_COMMIT=1
ROUTR_SIGNAL_PUBLISH=1
ROUTR_SIGNAL_DEBUG=0
